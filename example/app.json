{
  "expo": {
    "name": "ExpoIcloudStorageExample",
    "slug": "ExpoIcloudStorageExample",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
     "platforms": [
      "ios"
    ],
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.example.expoicloudstorage"
    },
    "plugins": [
      [
        "@oleg_svetlichnyi/expo-icloud-storage",
        {
          "containerIdentifier": "iCloud.com.example.expoicloudstorage",
          "containerName": "ExpoIcloudStorageExample",
          "isDocumentScopePublic": true
        }
      ],
      [
        "expo-build-properties",
          {
            "ios": {
            "useFrameworks": "static",
            "deploymentTarget": "15.5"
            }
        }
      ]
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
